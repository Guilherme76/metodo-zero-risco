# ──────────────────────────────────────────────────────────────
# Site
# ──────────────────────────────────────────────────────────────
# URL canônica do site. Usada em metadata, JSON-LD, OG, sitemap e robots.
NEXT_PUBLIC_SITE_URL="https://metodo-zero-risco.vercel.app"

# ──────────────────────────────────────────────────────────────
# Checkout
# ──────────────────────────────────────────────────────────────
# URL base do gateway de pagamento (Hotmart, Kiwify, Stripe Payment Link, etc.)
# Opcionalmente aceita ?plan=mensal|trimestral|semestral|anual
NEXT_PUBLIC_CHECKOUT_URL="https://pay.hotmart.com/RFP-SPORTS-VIP"

# Data/hora ISO em que a oferta atual expira (afeta o CountdownBanner).
# Default: 3 dias após o build se não definido.
# Exemplo: 2026-12-31T23:59:59-03:00
# NEXT_PUBLIC_CHECKOUT_DEADLINE=""

# ──────────────────────────────────────────────────────────────
# Telegram
# ──────────────────────────────────────────────────────────────
# Link direto do bot/canal oficial. Exibido no header, hero, footer
# e botão flutuante de contato.
NEXT_PUBLIC_TELEGRAM_URL="https://t.me/rfppagamentos_bot"

# ──────────────────────────────────────────────────────────────
# Analytics
# ──────────────────────────────────────────────────────────────
# Google Analytics 4 — Measurement ID (G-XXXXXXXXXX).
# Deixe vazio para não carregar.
# NEXT_PUBLIC_GA_ID=""

# Meta (Facebook) Pixel ID.
# Deixe vazio para não carregar.
# NEXT_PUBLIC_META_PIXEL_ID=""

# Google Search Console — verification token (conteúdo da meta tag).
# Deixe vazio para não incluir.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""
